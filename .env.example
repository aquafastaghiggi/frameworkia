# Configuração de Ambiente - Frameworkia

# APP
APP_NAME=Frameworkia
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:SUA_CHAVE_AQUI_COM_32_CARACTERES
APP_URL=http://localhost:8000

# DATABASE
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=frameworkia
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# OpenAI
OPENAI_API_KEY=seu-api-key-aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Redis (opcional)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# File Upload
MAX_UPLOAD_SIZE=52428800
UPLOAD_PATH=storage/uploads
DOCUMENTS_PATH=storage/documents
WORKSPACES_PATH=workspaces

# Security
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100
SESSION_TIMEOUT=1800

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# IDE Settings
IDE_MAX_TABS=20
IDE_AUTO_SAVE=true
IDE_AUTO_SAVE_INTERVAL=5000

# Git
GIT_EXECUTABLE=/usr/bin/git
GIT_TIMEOUT=30

# Cache
CACHE_DRIVER=file
CACHE_TTL=3600

# Admin
ADMIN_EMAIL=admin@frameworkia.local
ADMIN_PASSWORD=admin123
ENABLE_REGISTRATION=false
