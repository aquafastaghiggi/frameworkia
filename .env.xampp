# ============================================================
# FRAMEWORKIA - XAMPP LOCAL SETUP
# Arquivo de configuração pré-pronto para XAMPP
# ============================================================

# APP
APP_NAME=Frameworkia
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/frameworkia

# DATABASE - XAMPP DEFAULTS
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=frameworkia_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# OPENAI - USE MOCK FOR LOCAL TESTING
OPENAI_API_KEY=mock-key-local
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# REDIS - OPTIONAL (localhost)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# FILE UPLOAD
MAX_UPLOAD_SIZE=52428800
UPLOAD_PATH=storage/uploads
DOCUMENTS_PATH=storage/documents
WORKSPACES_PATH=workspaces

# SECURITY
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100
SESSION_TIMEOUT=1800

# LOGGING
LOG_CHANNEL=file
LOG_LEVEL=debug
LOG_PATH=storage/logs

# IDE SETTINGS
IDE_MAX_TABS=20
IDE_AUTO_SAVE=true
IDE_AUTO_SAVE_INTERVAL=5000

# GIT
GIT_EXECUTABLE=/usr/bin/git
GIT_TIMEOUT=30

# CACHE
CACHE_DRIVER=file
CACHE_TTL=3600

# ADMIN
ADMIN_EMAIL=admin@frameworkia.local
ADMIN_PASSWORD=admin123
ENABLE_REGISTRATION=false

# XAMPP PATHS
XAMPP_PATH=C:/xampp
PHP_BIN=php.exe
COMPOSER_BIN=composer.bat
